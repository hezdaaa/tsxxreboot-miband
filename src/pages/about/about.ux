          <text class="subtitle">小米手环移植版</text>  
          <text class="author">@hezdaaa</text> 
          
          <text class="section-title" if="{{isFirstVisit}}" >初次游玩前请仔细阅读以下内容！阅读完毕后即可开始游戏！</text> 

          <div class="section-divider"></div>
          
          <div class="instruction-item">
            <text class="bullet">•</text>
            <text class="instruction-text">点击换页</text>
          </div>
          <div class="instruction-item">
            <text class="bullet">•</text>
            <text class="instruction-text">左滑上一页</text>
          </div>
          <div class="instruction-item">
            <text class="bullet">•</text>
            <text class="instruction-text">长按隐藏文本框</text>
          </div>
