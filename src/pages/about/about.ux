            <text class="info-text">完整安装包有15mb，手环解压后23mb。</text> 
            <text class="info-text"></text> 
            <text class="info-text">攻略教程：BV1YCCrBjETx</text> 
            <text class="info-text"></text> 
            <text class="info-text">注：本快应用为非官方移植</text> 
          </div>
          
          <div class="contact-section">
            <text class="section-title">Q群</text> 
            <text class="highlight-text">224262549</text> 
            <text class="info-text">GitHub开源：https://github.com/hezdaaa/tsxxreboot-miband</text> 
            <text class="info-text">您的支持就是我最大的更新动力！</text>
          </div>
          
          <div class="original-info">
            <text class="info-text">移植自视觉小说</text> 
            <text class="app-name">天使☆嚣嚣 re-boot! </text> 
            <text class="fun-text">Ciallo～(∠ ·ω< )⌒★</text> 
          </div>
          <div class="update-info"  if="{{isFirstVisit}}"  >
            <text class="info-text">请先进入设置页面调整字体粗细等设置</text> 
          </div>
        </div>
        <!-- 初次访问时显示的底部按钮 -->
        <text class="acknowledge-btn" if="{{isFirstVisit}}"  onclick="acknowledge">我已知晓</text>
      <text class="title"></text> 
      </scroll>
      
      <!-- 左上角返回按钮：仅非初次访问时显示 -->
      <img class="back-btn" src="/common/back.png" onclick="back" if="{{!isFirstVisit}}"></img> 
    </div> 
  </template> 
  
  <script> 
  import router from '@system.router'
  import storage from '@system.storage'
  
  export default { 
    data: { 
      build: false,
      isFirstVisit: true    // 默认为初次访问，待读取存储后更新
    }, 
    noax() {
      console.log('swipe event prevented');
    },
    onInit() {
      // 读取是否已访问过 about 页面
      storage.get({
        key: 'about_visited2',
        success: (data) => {
          if (data === 'true') {
            this.isFirstVisit = false;  
          } else {
            this.isFirstVisit = true; 
          }
        },
        fail: () => {
          // 读取失败（键不存在），视为初次访问
          this.isFirstVisit = true;
        }
      });
    },
    
    back() { 
      router.back({ 
        uri: 'pages/index'
      }) 
    },
    setting() { 
      router.replace({ 
        uri: 'pages/settings'
      }) 
    },
    acknowledge() {
      // 标记已访问
      storage.set({
        key: 'about_visited2',
        value: 'true',
        success: () => {
          this.setting();   // 返回主页
        },
        fail: () => {
          this.setting();   // 即使存储失败也返回
        }
      });
    }
  }; 
  </script> 
  
