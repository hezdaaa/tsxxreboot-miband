            </div>
            <div class="info-container" if="{{lhuishow}}">
                <text class="info-text" if="{{lhuishow}}">背景: {{bgIndex + 1}}/{{backgroundList.length}}</text>
                <text class="info-text" if="{{lhuishow}}">角色: {{charIndex + 1}}/{{characterList.length}}</text>
            </div>
            <img class="last-btn1" src="/common/back.png" onclick="lastcgb" if="{{lhuishow}}"></img>
            <img class="enter-btn1" src="/common/go.png" onclick="entercgb" if="{{lhuishow}}"></img>
            <img class="last-btn" src="/common/back.png" onclick="lastlh" if="{{lhuishow}}"></img>
            <img class="enter-btn" src="/common/go.png" onclick="enterlh" if="{{lhuishow}}"></img>
        </div>
        
        <!-- 场景鉴赏页面 -->
        <div class="page2" if="{{sceneshow === true}}">
            <img class="bt" src="/common/bt.png"></img>
            <img class="hd" src="/common/hd.png"></img>
            <div class="header">
                <text class="title">场景鉴赏</text>
            </div>
            <img class="last-btn" src="/common/back.png" onclick="lastsc"></img>
            <img class="enter-btn" src="/common/go.png" onclick="entersc"></img>
            <div class="startBtn">
                <text class="startText" onclick="loadStart()">开始</text>
            </div>
        </div>
        
        <img class="back-btn" src="/common/back.png" onclick="back" if="{{jump || lhuishow && cguishow}}"></img>
    </div>
</template>

