    "/common/bcgi/街_公園a.jpg",
    "/common/bcgi/街_公園a_モブ.jpg",
    "/common/bcgi/街_公園b.jpg",
    "/common/bcgi/街_公園c.jpg",
    "/common/bcgi/街_公園霧.jpg",
    "/common/bcgi/街_通学路a.jpg",
    "/common/bcgi/街_通学路b.jpg",
    "/common/bcgi/街_通学路c.jpg",
    "/common/bcgi/街_道（繁華街）a.jpg",
    "/common/bcgi/街_道（繁華街）b.jpg",
    "/common/bcgi/街_道（繁華街）c.jpg",
    "/common/bcgi/街_駅前a.jpg",
    "/common/bcgi/街_駅前a_モブ.jpg",
    "/common/bcgi/街_駅前b.jpg",
    "/common/bcgi/街_駅前b_モブ.jpg",
    "/common/bcgi/街_駅前c.jpg",
    "/common/bcgi/街_駅前c_モブ.jpg"
        ],
        bgIndex: 0,
        currentBg: '/common/bcgi/空_夕.jpg',
        
        // 场景鉴赏相关
        sceneList: [],
        sceneIndex: 0,
        cguishow: true,
        lhchshow: true,
        lhuishow: true,
    },
    
    onInit() {
        console.log('鉴赏页面初始化');
        this.initImages();
    },
    
    // 初始化图片
    initImages() {
        console.log('初始化图片列表...');
        
        // 设置默认显示图片
        if (this.cgList.length > 0) {
            this.currentCG = this.cgList[0];
            console.log('设置默认CG:', this.currentCG);
        } else {
            console.log('CG列表为空');
        }
        
        if (this.characterList.length > 0) {
            this.currentChar = this.characterList[0];
            console.log('设置默认角色立绘:', this.currentChar);
        }
        
        if (this.backgroundList.length > 0) {
            this.currentBg = this.backgroundList[0];
            console.log('设置默认背景:', this.currentBg);
        }
        
        console.log('图片初始化完成');
        console.log('CG数量:', this.cgList.length);
        console.log('立绘数量:', this.characterList.length);
        console.log('背景数量:', this.backgroundList.length);
    },
    
    // ================= 页面切换方法 =================
    hidcgui(){
        this.cguishow = !this.cguishow;
    },
    hidlhch(){
        this.lhchshow = !this.lhchshow;
    },
    hidlhui(){
        this.lhuishow = !this.lhuishow;
    },
    showcg() {
        this.jump = false;
        this.cgshow = true;
        this.lhshow = false;
        this.sceneshow = false;
        
        // 确保有图片显示
        if (this.cgList.length > 0 && this.cgIndex < this.cgList.length) {
            this.currentCG = this.cgList[this.cgIndex];
        }
        
        console.log('进入CG鉴赏，当前CG:', this.currentCG);
    },
    
    showlh() {
        this.jump = false;
        this.cgshow = false;
        this.lhshow = true;
        this.sceneshow = false;
        
        // 确保有图片显示
        if (this.characterList.length > 0 && this.charIndex < this.characterList.length) {
            this.currentChar = this.characterList[this.charIndex];
        }
        if (this.backgroundList.length > 0 && this.bgIndex < this.backgroundList.length) {
            this.currentBg = this.backgroundList[this.bgIndex];
        }
        
        console.log('进入立绘鉴赏，当前角色:', this.currentChar, '背景:', this.currentBg);
    },
    
    showscene() {
        this.jump = false;
        this.cgshow = false;
        this.lhshow = false;
        this.sceneshow = true;
        console.log('进入场景鉴赏');
    },
    
    // ================= 图片切换方法 =================
    
    // CG上一张
    lastcg() {
        if (this.cgList.length === 0) {
            console.log('CG列表为空，无法切换');
            return;
        }
        
        this.cgIndex = (this.cgIndex - 1 + this.cgList.length) % this.cgList.length;
        this.currentCG = this.cgList[this.cgIndex];
        console.log('切换到CG:', this.cgIndex + 1, '/', this.cgList.length, '路径:', this.currentCG);
    },
    
    // CG下一张
    entercg() {
        if (this.cgList.length === 0) {
            console.log('CG列表为空，无法切换');
            return;
        }
        
        this.cgIndex = (this.cgIndex + 1) % this.cgList.length;
        this.currentCG = this.cgList[this.cgIndex];
        console.log('切换到CG:', this.cgIndex + 1, '/', this.cgList.length, '路径:', this.currentCG);
    },
    
    // 立绘上一个角色
    lastlh() {
        if (this.characterList.length === 0) {
            console.log('角色列表为空，无法切换');
            return;
        }
        
        this.charIndex = (this.charIndex - 1 + this.characterList.length) % this.characterList.length;
        this.currentChar = this.characterList[this.charIndex];
        console.log('切换到立绘:', this.charIndex + 1, '/', this.characterList.length, '路径:', this.currentChar);
    },
    
    // 立绘下一个角色
    enterlh() {
        if (this.characterList.length === 0) {
            console.log('角色列表为空，无法切换');
            return;
        }
        
        this.charIndex = (this.charIndex + 1) % this.characterList.length;
        this.currentChar = this.characterList[this.charIndex];
        console.log('切换到立绘:', this.charIndex + 1, '/', this.characterList.length, '路径:', this.currentChar);
    },
    
    // 背景上一个
    lastcgb() {
        if (this.backgroundList.length === 0) {
            console.log('背景列表为空，无法切换');
            return;
        }
        
        this.bgIndex = (this.bgIndex - 1 + this.backgroundList.length) % this.backgroundList.length;
        this.currentBg = this.backgroundList[this.bgIndex];
        console.log('切换到背景:', this.bgIndex + 1, '/', this.backgroundList.length, '路径:', this.currentBg);
    },
    
    // 背景下一个
    entercgb() {
        if (this.backgroundList.length === 0) {
            console.log('背景列表为空，无法切换');
            return;
        }
        
        this.bgIndex = (this.bgIndex + 1) % this.backgroundList.length;
        this.currentBg = this.backgroundList[this.bgIndex];
        console.log('切换到背景:', this.bgIndex + 1, '/', this.backgroundList.length, '路径:', this.currentBg);
    },
    
    // 返回按钮
    back() {
        if (this.jump === true) {
            router.back({
                uri: 'pages/more',
            });
        } else {
            this.jump = true;
            this.cgshow = false;
            this.lhshow = false;
            this.sceneshow = false;
            console.log('返回主菜单');
        }
    },
    
    // 场景鉴赏相关方法（预留）
    lastsc() {
        console.log('上一个场景');
    },
    
    entersc() {
        console.log('下一个场景');
    },
    
    loadStart() {
        console.log('开始场景鉴赏');
    }
};
</script>

