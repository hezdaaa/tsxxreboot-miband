<template>
    <div class="page">
        <img class="bcg" src="/common/bcgi/空_夕.jpg"></img>
        <img class="bt" src="/common/bt.png"></img>
        <img class="hd" src="/common/hd.png"></img>
        
        <!-- 主菜单 -->
        <div class="page2" if="{{jump === true}}">
            <div class="header">
                <text class="title">鉴赏模式</text>
            </div>
            <div class="content" onclick="showcg">
                <text class="mid">CG鉴赏</text>
            </div>
            <div class="content" onclick="showlh">
                <text class="mid">立绘鉴赏</text>
            </div>
        </div>
        
        <!-- CG鉴赏页面 -->
        <div class="page2" if="{{cgshow === true}}" >
            <image class="cgimg" src="{{currentCG}}" onclick="hidcgui"></image>
            <img class="bt" src="/common/bt.png" if="{{cguishow}}"></img>
            <img class="hd" src="/common/hd.png" if="{{cguishow}}"></img>
            <div class="header">
                <text class="title" if="{{cguishow}}">CG鉴赏</text>
            </div>
            
            <div class="info-container" >
                <text class="info-text" if="{{cguishow}}">{{cgIndex + 1}}/{{cgList.length}}</text>
            </div>
            
            <img class="last-btn" src="/common/back.png"  if="{{cguishow}}" onclick="lastcg"></img>
            <img class="enter-btn" src="/common/go.png"  if="{{cguishow}}" onclick="entercg"></img>
        </div>
        
        <!-- 立绘鉴赏页面 -->
        <div class="page2" if="{{lhshow === true}}">
            <image class="backgroundimg" src="{{currentBg}}" onclick="hidlhch"></image>
            <image class="character" src="{{currentChar}}" onclick="hidlhui" if="{{lhchshow}}"></image>
