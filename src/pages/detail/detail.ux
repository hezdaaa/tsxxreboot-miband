<template>
  <div class="page" @swipe="pageSwipe" onlongpress="displayPage" onclick="playPage">
    
    <!-- 当前背景，缩放类绑定 -->
    <image class="backgroundimg {{currentBackgroundScaleClass}}" 
           src="{{currentBackground}}"
           onerror="onImageError('background', currentBackground)"></image>
    <!-- 下一张背景 -->
    <image class="backgroundimg next-background {{nextBackgroundScaleClass}}" 
           src="{{nextBackground}}" if="{{showNextBackground}}"
           onerror="onImageError('nextBackground', nextBackground)"></image>
  
    <!-- 当前CG图层 -->
    <image class="cgimg" src="{{cgimg}}" if="{{cgimg}}"
           onerror="onImageError('cg', cgimg)"></image>
    <!-- 下一张CG -->
    <image class="cgimg next-cg" src="{{nextCg}}" if="{{showNextCg}}"
           onerror="onImageError('nextCg', nextCg)"></image>
    
    <!-- 立绘图层，缩放类绑定 -->
    <div class="character-container" if="{{characterimg}}">
      <image class="characterimg {{currentCharacterScaleClass}}" 
             src="{{characterimg}}"
             onerror="onImageError('character', characterimg)"></image>
    </div>
    <!-- 下一张立绘 -->
    <div class="character-container" if="{{nextCharacterImg && showNextCharacter}}">
      <image class="characterimg next-character {{nextCharacterScaleClass}}" 
             src="{{nextCharacterImg}}"
             onerror="onImageError('nextCharacter', nextCharacterImg)"></image>
    </div>

    <!-- 对话框（结局时隐藏） -->
    <image class="board" src="board.png" onclick="nextPage" if="{{pageShow === true && !hideText && !isEnding}}"></image>

    <!-- 角色名（结局时隐藏） -->
    <text class="character" style=" color: {{viewed ? readColor : unreadColor}}; font-weight: {{boldText ? 'bold' : 'normal'}};" if="{{pageShow === true && !hideText && !isEnding}}">{{displayCharacter}}</text>

    <!-- 文本内容（结局时隐藏） -->
    <scroll id="Scroll" class="scroll2" onclick="nextPage" scroll-y="{{true}}" bounces="{{true}}" if="{{!isEnding}}">
      <text class="contect" 
        style="color: {{viewed ? readColor : unreadColor}}; font-size: {{currentTextFontSize}}px; font-weight: {{boldText ? 'bold' : 'normal'}};" 
        if="{{pageShow === true && !hideText}}">
        {{displayText}}
      </text>
    </scroll>
    
    <!-- 黑色遮罩层（用于背景切换动画） -->
    <div class="background-mask" style="background-color: {{maskColor}};" if="{{isAnimating}}"></div>
    
    <!-- 闪光弹白色遮罩层（最高优先级） -->
    <div class="flashbang-mask" if="{{showFlashbang}}" onclick="nextPage" style="opacity: {{flashbangOpacity}};"></div>
      
    <!-- 控制按钮（结局时隐藏） -->
    <div class="skip-btn2" if="{{isAutoing && !contrlcenterShow && !isAnimating && !isEnding}}" onclick="stopAutoplay">
      <text>停止自动播放</text>
    </div>
    <div class="skip-btn3" if="{{isGoing && !contrlcenterShow && !isAnimating && !isEnding}}" onclick="stopQuickGo">
      <text>停止快进</text>
    </div>
    <div class="skip-btn4" if="{{isBacking && !contrlcenterShow && !isAnimating && !isEnding}}" onclick="stopQuickBack">
      <text>停止快退</text>
    </div>
    
    <!-- 选择选项（结局时隐藏） -->
    <div class="choose" if="{{choose && pageShow === true && !isAnimating && !isEnding}}">
      <text class="choosetext" onclick="choose1c" if="{{choose1Visible}}" style="color: {{choose1Color}};">{{choose1}}</text>
      <text class="choosetext" onclick="choose2c" if="{{choose2Visible}}" style="color: {{choose2Color}};">{{choose2}}</text>
      <text class="choosetext" onclick="choose3c" if="{{choose3Visible}}" style="color: {{choose3Color}};">{{choose3}}</text>
      <text class="choosetext" onclick="choose4c" if="{{choose4Visible}}" style="color: {{choose4Color}};">{{choose4}}</text>
      <!-- 第五个选项 -->
      <text class="choosetext" onclick="choose5c" if="{{choose5Visible}}" style="color: {{choose5Color}};">{{choose5}}</text>
    </div>
    
    <!-- 控制中心（结局时隐藏） -->
    <div class="page1" if="{{contrlcenterShow && !isAnimating && !isEnding}}" @swipe="controlCenterSwipe">
      <scroll id="mainScroll" class="scroll" scroll-y="{{true}}" bounces="{{true}}">
        <text class="load2">{{nowTime}} | {{readProgress}}</text>
        <text class="load" onclick="hidecontrlcenter">返回</text>
        <text class="load" onclick="saveconShow">保存</text>
        <text class="load" onclick="loadconShow">加载</text>
        <text class="load" onclick="quickSave">快速存档</text>
        <text class="load" onclick="loadStart(1)">快速读档</text>
        <text class="load" onclick="indexRoute">返回主页</text>
        <text class="load" onclick="settingsRoute">设置</text>
        <text class="load" onclick="lctRoute">流程图</text>
        <text class="load" onclick="autoplay" if="{{isBacking === false && isGoing === false}}">{{isAutoing ? '停止自动播放' : '自动播放'}}</text>
        <text class="load" onclick="quickgo" if="{{isBacking === false && isAutoing === false}}">{{isGoing ? '停止快进' : '快进'}}</text>
        <text class="load" onclick="quickback" if="{{isAutoing === false && isGoing === false}}">{{isBacking ? '停止快退' : '快退'}}</text>
        <text class="load2"></text>
      </scroll>
    </div>

    <!-- 读档页面 -->
    <div class="page1" if="{{loadShow && !isAnimating && !isEnding}}" @swipe="loadSaveSwipe">
      <text class="load3" onclick="loadconShow">点击跳转至对应页面</text>
      <scroll id="loadScroll" class="scroll" scroll-y="{{true}}" bounces="{{true}}">
        <div class="save-item" for="{{(index, item) in saveSlots}}" onclick="loadSlot(index + 1)">
          <text class="load">存档{{index + 1}}: {{item.text}}</text>
        </div>
        <text class="load2"></text>
      </scroll>
    </div>

    <!-- 存档页面 -->
    <div class="page1" if="{{saveShow && !isAnimating && !isEnding}}" @swipe="loadSaveSwipe">
      <text class="load3" onclick="saveconShow">长按删除存档位</text>
      <scroll id="saveScroll" class="scroll" scroll-y="{{true}}" bounces="{{true}}">
        <div class="save-item" for="{{(index, item) in saveSlots}}">
          <text class="load" onlongpress="deleteSlot(index + 1)" onclick="saveToSlot(index + 1)">存档{{index + 1}}: {{item.text}}</text>
        </div>
        <div class="save-add" onclick="addSaveSlot">
          <text class="load">[ + 添加存档位 ]</text>
        </div>
        <text class="load2"></text>
      </scroll>
    </div>

    <!-- 结局画面覆盖层 -->
    <div class="end-overlay" if="{{isEnding && endAnimationDone}}" onclick="endClickReturn">
      <text class="end-text">{{endText}}</text>
    </div>
  </div>
</template>

