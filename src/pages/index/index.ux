  background-color: rgba(255, 255, 255, 0);
  justify-content: flex-start;
  align-items: flex-end;
  top: 15px;
  right: 250px;
  position: absolute;
}
.hd{
    position: absolute;
    top: 0;
}
.background{
  top:0px;
  position: absolute;
}
.background2{
  top:100px;
  position: absolute;
}
.reset2{
  background-color: rgba(255, 255, 255, 0);
  justify-content: flex-start;
  align-items: flex-end;
  bottom: 15px;
  right: 15px;
  position: absolute;
}
.logo{
  top: 80px;
}
.settings{
  background-color: rgba(255, 255, 255, 0);
  justify-content: flex-start;
  align-items: flex-end;
  top: 15px;
  left: 250px;
  position: absolute;
}
.reset{
  background-color: rgba(255, 255, 255, 0);
  justify-content: flex-start;
  align-items: flex-end;
  bottom: 100px;
  right: 15px;
  position: absolute;
}
.back{
  background-color: rgba(255, 255, 255, 0);
  justify-content: flex-start;
  align-items: flex-end;
  bottom: 15px;
  right: 15px;
  position: absolute;
}
.group-1{
  top:40px;
  flex-direction: column;
  width: 80%;
}
.mid{
  margin-bottom:10px;
  font-size: 35px;
  color: #000;
  font-weight: 800;
}
.bc{
  position: absolute;
  width: 336px;
  height: 480px;
  top: 0;
  left: 0;
  background-color: rgb(47, 52, 116);
  z-index: -1;
}
.page1{
  margin-top:50px;
  position: absolute;
  background-color: rgba(255, 255, 255, 0.877);
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  margin: auto;
  width: 100%;
}
.page3{
  position: absolute;
  background-color: rgba(255, 255, 255, 0.877);
  flex-direction: column;
  justify-content: center;
  align-items: center;
  margin: auto;
  width: 100%;
  bottom: 0;
  top:0;
}
.load{
  margin-top: 20px;
  font-size: 35px;
  color: #000;
  font-weight: 800;
  width: 80%;
  background-color: rgba(167, 223, 255, 0.486);
}
.load2{
  margin-top: 15px;
  font-size: 40px;
  color: #000;
  font-weight: 800;
  width: 80%;
}

.scroll{
  top:5px;
  height: 400px;
  text-align: left;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  z-index: 0;
  flex: 1;
  width: 100%;
}

/* 存档项目样式 */
.save-item {
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
</style>